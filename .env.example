# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Required for hard_fact_extraction.py and soft_fact_extraction.py
ANTHROPIC_API_KEY=sk-ant-...

# Optional — only needed if you want images served from S3
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=eu-central-2

# Optional — override default paths
# LISTINGS_RAW_DATA_DIR=./raw_data
# LISTINGS_DB_PATH=./data/listings.db

# Optional — MCP server
# APPS_SDK_LISTINGS_API_BASE_URL=http://localhost:8000
# APPS_SDK_PUBLIC_BASE_URL=http://localhost:8001
